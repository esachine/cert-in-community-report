# Dependencies (Hostinger/GitHub install these during deploy - never commit them)
node_modules/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment / secrets (this project has none, but keep them out just in case)
.env
.env.*

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Editor / IDE
.vscode/
.idea/
*.swp

# Scratch / temp
agent-tools/
tmp/
*.tmp

# NOTE: data/ and public/ ARE committed on purpose - they are the generated
# content the site serves and what GitHub Actions refreshes.
